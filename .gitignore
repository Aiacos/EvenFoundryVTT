# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
*.tsbuildinfo

# Caches
.cache/
.vite/
.parcel-cache/

# Test artifacts
coverage/
.nyc_output/
.vitest-cache/

# Changesets working cache (committed: .changeset/*.md, config.json, README.md)
.changeset/__cache__/

# Husky internals (committed: .husky/{commit-msg,pre-commit})
.husky/_/

# OS junk
.DS_Store
Thumbs.db

# Editor
.idea/
.vscode/
*.swp
*~

# Logs
*.log

# Env files (defense-in-depth — repo should never need these)
.env
.env.local
.env.*.local
*.secret.json

# deploy: never commit real secrets (deploy/.env.example is the template)
deploy/.env
deploy/.env.local
# Headless player-view saved Forge session (storageState) — sensitive, never commit.
deploy/secrets/

# Even Hub package bundles — build artifacts, regenerated via `pnpm --filter @evf/g2-app pack:ehpk`
*.ehpk

# Simulator harness runtime directory — pid files, log files (gitignored, regenerated on start)
.sim-run/

# Scratch + build dirs (never commit; only ignore — do not delete existing files)
# _*.ts: ad-hoc scratch scripts (e.g. packages/bridge/_seed.ts, packages/foundry-module/_scene_e2e.ts)
_*.ts
# release/: foundry-module staging output (packages/foundry-module/release/)
release/
# release-artifacts/: root release staging dir
release-artifacts/
/chrome/
