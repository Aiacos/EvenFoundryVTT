# EvenFoundryVTT bridge environment template.
# Copy to deploy/.env and fill with real values. NEVER commit deploy/.env.
#
# Generate EVF_INTERNAL_SECRET via:
#   openssl rand -base64 32

# 32-byte random secret for module → bridge /internal/delta auth.
# Required in production (bridge refuses to start if missing or empty).
# Specs.md §11.5.4 — bearer opaque 24h, paired via QR scan.
EVF_INTERNAL_SECRET=replace-with-openssl-rand-base64-32

# CORS allow-list origin (the Plugin Host URL where g2-app is served).
# Specs.md §3.3: NO wildcards. Origin-complete URL only.
# Example for local Vite dev server: http://localhost:5173
# Example for production: https://g2app.yourdomain.com
EVF_PLUGIN_HOST_URL=http://localhost:5173
