# EvenFoundryVTT bridge environment template.
# Copy to deploy/.env and fill with real values. NEVER commit deploy/.env.
#
# Generate EVF_INTERNAL_SECRET via:
#   openssl rand -base64 32

# 32-byte random secret for module → bridge /internal/delta auth.
# Required in production (bridge refuses to start if missing or empty).
# Specs.md §11.5.4 — bearer opaque 24h, paired via QR scan.
EVF_INTERNAL_SECRET=replace-with-openssl-rand-base64-32

# CORS allow-list origin (the Plugin Host URL where g2-app is served).
# Specs.md §3.3: NO wildcards. Origin-complete URL only.
# Example for local Vite dev server: http://localhost:5173
# Example for production: https://evf-plugin.yourdomain.com  (= https://${EVF_PLUGIN_HOST})
EVF_PLUGIN_HOST_URL=http://localhost:5173

# ─── HTTPS deploy (Caddy reverse proxy — docker-compose.https.yml) ───────────
#
# Real, publicly-resolvable hostnames (DNS A records → this host; ports 80/443 reachable).
# Caddy auto-provisions Let's Encrypt certs. No public IP? Front with a tunnel
# (Cloudflare Tunnel / Tailscale Funnel) — see docs/release/evenhub.md.
# These two HTTPS origins are exactly the app.json whitelist:
#   node deploy/sync-app-whitelist.mjs   # writes them into packages/g2-app/app.json
EVF_BRIDGE_HOST=evf-bridge.example.com
EVF_PLUGIN_HOST=evf-plugin.example.com

# ─── Full TEST stack: Foundry VTT (docker-compose.foundry-test.yml) ──────────
#
# Foundry VTT is LICENSED. The felddy/foundryvtt image downloads it with YOUR Foundry
# account credentials (https://foundryvtt.com). Without these, Foundry will not start.
FOUNDRY_USERNAME=
FOUNDRY_PASSWORD=
# Admin password for the Foundry setup/admin screen (you choose this).
FOUNDRY_ADMIN_KEY=evf-admin

# ─── Phase 11 V2 MCP server (foundry-mcp) ────────────────────────────────────

# Bearer token forwarded to the bridge for every MCP tool invocation.
# Use the same 24h bearer issued by the Phase 2 QR-pairing flow.
EVF_BEARER=

# Bridge URL the MCP server connects to over WS for tool dispatch + delta sub.
# Compose default resolves via service DNS: http://bridge:8910
EVF_BRIDGE_URL=http://bridge:8910

# (optional) Specific Foundry actor ID; blank = auto-detect first owned actor.
EVF_ACTOR_ID=

# (optional) HTTP port the MCP Streamable HTTP transport binds. Default 8911.
MCP_HTTP_PORT=8911

# ─── Phase 12 voice path (optional) ─────────────────────────────────────────

# Deepgram API key for Nova-3 Multilingual streaming STT.
# Obtain from https://console.deepgram.com/ → API Keys → Create New Key
# (Speech permission, Member scope minimum).
# When not set, bridge starts in soft-fail mode: /v1/audio/stream closes with
# code 1011 + 'voice-disabled' — all MVP routes remain fully operational.
# NEVER commit a real key. NEVER paste in source code.
# DEEPGRAM_API_KEY=REPLACE_WITH_DEEPGRAM_API_KEY_FROM_CONSOLE

# (optional) Override the Deepgram WebSocket URL for integration testing.
# Default: wss://api.deepgram.com/v1/listen?model=nova-3&language=multi&...
# EVF_DEEPGRAM_URL_OVERRIDE=ws://localhost:9999/mock-deepgram

# ─── Player view (headless) — ADR-0015 §C P2 ─────────────────────────────────
# Headless Chromium logs into Foundry as the selected player to stream THEIR
# real view (lighting + fog). Server-side, managed by the homelab host (master).
# NEVER commit deploy/.env — only this template.
#
# The Forge game URL the headless session opens.
EVF_PLAYER_VIEW_FOUNDRY_URL=https://your-world.forge-vtt.com
# Forge account (the streaming/player account). Auto-login is ATTEMPTED first;
# Google-SSO auto-login is unreliable (Google blocks automation) so the
# orchestrator falls back to the saved storageState session below.
EVF_PLAYER_VIEW_FORGE_USER=
EVF_PLAYER_VIEW_FORGE_PASSWORD=
# Path (in-container) to the persisted Playwright session, populated by the
# one-time auth bootstrap and reused headlessly. Mount from a host volume; this
# file is the reliable auth path when Google-SSO auto-login fails.
EVF_PLAYER_VIEW_STORAGE_STATE=/app/secrets/forge-session.json
# Foundry WORLD username the `streaming` map-view joins as on the /join screen
# (blank password — Foundry users have no password by default). This is the
# streamer's intended map source: pick a user whose live Foundry viewport frames
# the party (e.g. a GM, or a dedicated observer). STRONGLY RECOMMENDED — when
# unset, streaming joins the FIRST /join user option (non-deterministic, often a
# fogged player → single-token view instead of the party). Must match the option
# label exactly. Loaded into the container via env_file (no compose change needed).
EVF_PLAYER_VIEW_STREAM_USER=
# ANGLE GL backend for the headless Chromium. Default (unset) = `vulkan`:
# HARDWARE GL via Mesa radv over the passed-through GPU (REQUIRED for a usable
# frame rate — software GL streams at ~0.1 fps). Set to `gl` to force the llvmpipe
# software fallback on hosts without a Vulkan driver / GPU passthrough.
# EVF_PLAYER_VIEW_GL=vulkan
