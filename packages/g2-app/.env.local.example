# g2-app DEV-ONLY escape hatch — copy to `.env.local` (gitignored) for local dev.
#
# Feature 001 (D1): the DEFAULT user path is install + paste {bridgeUrl, token}
# into the running plugin (no QR — the glasses have no camera). There is NO
# implicit `localhost` default any more. These two vars are an EXPLICITLY-gated
# dev convenience so a tester does not retype the URL / token on every reload.
# They are read at build time by Vite (`import.meta.env.VITE_*`) and are UNSET in
# production `.ehpk` builds, so the branches they enable are dead code there.
#
# WARNING (local test caveat): Vite also loads `.env.local` into the Vitest run.
# Setting VITE_EVF_NO_AUTH=true here makes the pairing wizard skip the token step
# in LOCAL test runs (the 6 wizard tests then assert against the no-auth flow).
# CI does not have `.env.local`, so the suite is green there. Unset NO_AUTH (or
# remove `.env.local`) to run the wizard tests against the real token flow locally.

# Skip the token step + send an empty bearer (only works against a bridge started
# with EVF_DEV_NO_AUTH=true). Explicit opt-in; never keyed off import.meta.env.DEV.
VITE_EVF_NO_AUTH=true

# Explicit dev bridge origin (point at your reachable bridge — NOT localhost if you
# test on a phone). Replaces the removed implicit localhost default.
VITE_EVF_DEV_BRIDGE_URL=https://your-bridge.example

# Automatic token pass (Feature 001 Option A) — DEV-ONLY, via a URL PARAM (not an env
# var): when no-auth is active, open the app with `?token=<real-24h-bearer>` (and
# optionally `&actor=<actorId>`) and that token is sent INSTEAD of the dev sentinel —
# so REAL character snapshots load without pasting into the wizard. Examples:
#   simulator:  evenhub-simulator "http://localhost:5173/?token=<TOKEN>&actor=<ID>" ...
#   dev QR:     evenhub qr --port 5173   (point the QR URL at /?token=<TOKEN>)
# The param is ignored entirely in a production (.ehpk) build (no-auth off). Never put
# a real bearer in a committed file / a shared QR — it is a live 24h credential.
