{
  "name": "@evf/foundry-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "EVF Phase 11 V2 MCP server — exposes the Tool Registry over stdio + Streamable HTTP for Claude Desktop and remote MCP clients.",
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/index.ts",
    "dev:http": "tsx watch src/http.ts",
    "start:stdio": "node dist/index.js",
    "start:http": "node dist/http.js",
    "typecheck": "tsc --noEmit",
    "lint:ci": "biome ci .",
    "test": "vitest --run",
    "test:smoke": "pnpm build && vitest run src/__tests__/mcp-inspector-smoke.test.ts"
  },
  "dependencies": {
    "@evf/shared-protocol": "workspace:*",
    "@modelcontextprotocol/sdk": "1.29.0",
    "pino": "10.3.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "25.6.2",
    "@vitest/coverage-v8": "4.1.5",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.8.3",
    "vitest": "4.1.5"
  }
}
