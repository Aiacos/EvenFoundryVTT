{
  "id": "evenfoundryvtt",
  "title": "EvenFoundryVTT",
  "description": "Projects your Foundry VTT D&D 5e session onto Even Realities G2 AR glasses, driven by Even R1 ring gestures.",
  "version": "0.1.29",
  "authors": [
    {
      "name": "EvenFoundryVTT",
      "url": "https://github.com/Aiacos/EvenFoundryVTT"
    }
  ],
  "url": "https://github.com/Aiacos/EvenFoundryVTT",
  "readme": "https://github.com/Aiacos/EvenFoundryVTT#readme",
  "manual": "https://aiacos.github.io/EvenFoundryVTT/showcase/",
  "bugs": "https://github.com/Aiacos/EvenFoundryVTT/issues",
  "changelog": "https://github.com/Aiacos/EvenFoundryVTT/releases",
  "manifest": "https://github.com/Aiacos/EvenFoundryVTT/releases/latest/download/module.json",
  "download": "https://github.com/Aiacos/EvenFoundryVTT/releases/download/v0.1.29/evenfoundryvtt.zip",
  "compatibility": {
    "minimum": "13.347",
    "verified": "14"
  },
  "esmodules": ["dist/module.js"],
