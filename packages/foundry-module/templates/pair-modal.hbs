{{!--
  pair-modal.hbs — EvenFoundryVTT ApplicationV2 pair modal template.

  Rendered by PairModal._prepareContext() → ApplicationV2 template engine.
  All user-facing strings come from {{i18n.*}} (pre-resolved in _prepareContext, never raw keys).

  Pairing model: the Even Hub platform exposes no camera / QR-scan API to apps (canonical:
  "no camera (there is none)"). The token is therefore COPIED here and PASTED into the g2-app
  wizard step 2 on the phone. The bridge URL and bearer token are rendered as copyable text;
  the token is masked by default and revealed only on explicit "Reveal" action. The token
  value is rendered via {{token}} (escaped) — never via triple-mustache / innerHTML.

  Boolean flags precomputed in _prepareContext (no `eq` helper required — Foundry does not
  register `eq` by default):
    - isEmpty         — state === "empty"
    - isExpired       — state === "expired"
    - isRefreshNeeded — state === "refresh-needed"
    - isPairing       — state === "pairing-in-progress"
    - showCredentials — state is active | refresh-needed | pairing-in-progress

  States handled:
    - "empty"              — no devices paired; informational copy + generate first code CTA
    - "active"             — copyable bridge URL + token; countdown timer; paired devices table
    - "pairing-in-progress"— same as active + spinner
    - "refresh-needed"     — credentials shown; countdown accent-coloured; Refresh CTA
    - "expired"            — expired banner; no credentials; paired devices still shown

  Accessibility:
    - Token field labelled; reveal/copy buttons have aria-labels via i18n
    - Countdown wrapped in <time datetime="...">
    - Device table has <thead> with <th scope="col">
    - Revoke buttons have aria-label="Revoke {alias}"
    - Inline confirmation uses aria-live="polite"

  @see 02-UI-SPEC.md §UI-A (layout, wireframe, i18n keys, accessibility)
  @see packages/foundry-module/src/pair/PairModal.ts (_prepareContext context shape)
--}}

<div class="evf-pair-modal">

  {{!-- ── Credentials Region ────────────────────────────────────────────────── --}}
  {{#unless isEmpty}}
  <section class="evf-pair-modal__cred-region">

    {{#if isExpired}}
    {{!-- Expired state: banner instead of credentials --}}
    <div class="evf-pair-modal__expired-banner" role="alert">
      <h2>{{i18n.expiredTitle}}</h2>
      <p>{{i18n.expiredBody}}</p>
      <button type="button" data-action="new-code" class="evf-btn evf-btn--primary">
        {{i18n.expiredCta}}
      </button>
    </div>

    {{else}}
    {{!-- active | refresh-needed | pairing-in-progress: show copyable credentials --}}
    <p class="evf-pair-modal__copy-instruction">{{i18n.copyInstruction}}</p>

    {{!-- Self-service pairing (ADR-0014): the bearer is bound to the CURRENT user's
          own authenticated identity — there is no user picker; you pair only your
          own device. --}}

    {{!-- Bridge URL (always visible, copyable) --}}
    <div class="evf-pair-modal__cred-field">
      <span class="evf-pair-modal__cred-label">{{i18n.copyBridgeUrl}}</span>
      <code class="evf-pair-modal__cred-value" data-bridge-url>{{bridgeUrl}}</code>
      <button
        type="button"
        class="evf-btn evf-btn--ghost evf-pair-modal__copy-btn"
        data-action="copy"
        data-copy-value="{{bridgeUrl}}"
        aria-label="{{i18n.copyButton}} {{i18n.copyBridgeUrl}}"
      >
        {{i18n.copyButton}}
      </button>
    </div>

    {{!-- Token (masked by default, reveal + copy) --}}
    <div class="evf-pair-modal__cred-field">
      <span class="evf-pair-modal__cred-label">{{i18n.copyToken}}</span>
      <code class="evf-pair-modal__cred-value" data-token-mask aria-hidden="true">••••••••••••••••••••••••</code>
      <code class="evf-pair-modal__cred-value evf-hidden" data-token-plain>{{token}}</code>
      <button
        type="button"
        class="evf-btn evf-btn--ghost evf-pair-modal__reveal-btn"
        data-action="reveal-token"
        aria-label="{{i18n.copyReveal}} {{i18n.copyToken}}"
      >
        {{i18n.copyReveal}}
      </button>
      <button
        type="button"
        class="evf-btn evf-btn--ghost evf-pair-modal__copy-btn"
        data-action="copy"
        data-copy-value="{{token}}"
        aria-label="{{i18n.copyButton}} {{i18n.copyToken}}"
      >
        {{i18n.copyButton}}
      </button>
    </div>

    <div class="evf-pair-modal__ttl-row">
      {{!-- Countdown: expiresAtMs (epoch ms) read by JS every 60s; expiresIso for datetime attr --}}
      <span class="evf-pair-modal__expires-label">{{i18n.expiresIn}}</span>
      <time
        class="evf-pair-modal__ttl{{#if isRefreshNeeded}} evf-ttl--urgent{{/if}}"
        datetime="{{expiresIso}}"
        data-countdown
        data-expires="{{expiresAtMs}}"
      >
        {{ttlDisplay}}
      </time>

      {{#if isRefreshNeeded}}
      <button type="button" data-action="refresh" class="evf-btn evf-btn--accent">
        {{i18n.refresh}}
      </button>
      {{/if}}

      {{!-- Active state: explicit "generate a new token" CTA (mints a fresh bearer
            bound to the current user). Without this the active state offered only
            Revoke, with no way to re-pair / rotate. --}}
      {{#if isActive}}
      <button type="button" data-action="new-code" class="evf-btn evf-btn--primary">
        {{i18n.regenerate}}
      </button>
      {{/if}}
    </div>

    {{#if isPairing}}
    <div class="evf-pair-modal__awaiting" role="status" aria-live="polite">
      <span class="evf-spinner" aria-hidden="true">↺</span>
      <span>{{i18n.awaiting}}</span>
    </div>
    {{/if}}

    {{/if}}{{!-- end isExpired/active branch --}}
  </section>
  {{/unless}}

  {{!-- ── Empty state: generate first pairing code ───────────────────────────── --}}
  {{#if isEmpty}}
  <section class="evf-pair-modal__empty-state">
    <p class="evf-pair-modal__empty-heading">{{i18n.emptyHeading}}</p>
    <p class="evf-pair-modal__empty-body">{{i18n.emptyBody}}</p>

    {{!-- Self-service pairing (ADR-0014): the first device is bound to the current
          user's own authenticated identity — no user picker. --}}

    <button type="button" data-action="new-code" class="evf-btn evf-btn--primary">
      {{i18n.expiredCta}}
    </button>
  </section>
  {{/if}}

  {{!-- ── Paired Devices Table ──────────────────────────────────────────────── --}}
  {{#unless isEmpty}}
  <section class="evf-pair-modal__devices">
    <h2 class="evf-pair-modal__devices-heading">{{i18n.tableHeading}}</h2>
    <hr class="evf-pair-modal__divider" />

    {{#if devices.length}}
    <div class="evf-pair-modal__table-wrap">
      <table class="evf-pair-modal__table">
        <thead>
          <tr>
            <th scope="col">{{i18n.colAlias}}</th>
            <th scope="col">{{i18n.colPaired}}</th>
            <th scope="col">{{i18n.colLastSeen}}</th>
            <th scope="col">{{i18n.colAction}}</th>
          </tr>
        </thead>
        <tbody>
          {{#each devices}}
          <tr class="evf-pair-modal__device-row" data-token-id="{{this.token}}">
            <td class="evf-pair-modal__alias" title="{{this.alias}}">{{this.alias}}</td>
            <td class="evf-pair-modal__paired-date">{{this.pairedDate}}</td>
            <td class="evf-pair-modal__last-seen">{{this.lastSeenRelative}}</td>
            <td class="evf-pair-modal__action" aria-live="polite">
              <button
                type="button"
                class="evf-btn evf-btn--destructive evf-revoke-btn"
                data-action="revoke"
                data-token-id="{{this.token}}"
                aria-label="{{../i18n.revokeButton}} {{this.alias}}"
              >
                {{../i18n.revokeButton}}
              </button>
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>

    {{else}}
    {{!-- Expired/active state with no devices (edge case) --}}
    <p class="evf-pair-modal__empty-heading">{{i18n.emptyHeading}}</p>
    <p class="evf-pair-modal__empty-body">{{i18n.emptyBody}}</p>
    {{/if}}
  </section>
  {{/unless}}

  {{!-- ── Footer ───────────────────────────────────────────────────────────── --}}
  <footer class="evf-pair-modal__footer">
    <button type="button" class="evf-btn" data-action="close">
      {{i18n.close}}
    </button>
  </footer>

</div>
