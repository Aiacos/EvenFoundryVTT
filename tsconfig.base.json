{
  // Source: TypeScript handbook (verified 2026-05-11) + tests/phase-0/tsconfig.json (Phase 0 proven green)
  //
  // Exclude all packages — each has its own tsconfig.json (extends this base)
  // and is type-checked by `pnpm -r exec tsc --noEmit`. The root pass only
  // covers workspace-level files (e.g., vitest.config.ts). This avoids
  // double-checking package sources against the root's narrower lib set
  // (ES2023-only, no DOM), which would otherwise break packages that
  // legitimately declare DOM types in their own tsconfig (g2-app, foundry-module).
  "exclude": ["packages"],
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023"],
    "types": [],

    // INV-4 strict mode (D-1.04 — verbatim Phase 0)
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    // ESM hygiene
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": false,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,

    // No emit at base level — each package decides
    "noEmit": true
  }
}
