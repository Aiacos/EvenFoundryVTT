# Strict by default — INV-4 wants dependency rigor
shamefully-hoist=false
# Avoid auto-install peer deps (force explicit declaration)
auto-install-peers=false
# Allow workspace:* protocol (default true in pnpm 10, explicit for clarity)
link-workspace-packages=true
# T-01-01 mitigation — disable lifecycle scripts of dependencies by default
# (allowed scripts can be granted explicitly via pnpm.onlyBuiltDependencies in package.json)
ignore-scripts=true
